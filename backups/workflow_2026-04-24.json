    {
      "parameters": {
        "jsCode": "// Extrai dados da mensagem recebida pelo WAHA\nconst body = $input.first().json.body;\n\n// Payload WAHA\nconst payload = body.payload || body;\n// Se 'from' tem @lid, é um ID interno — precisamos do número real\n// O número real do remetente está no campo 'to' de '_data' ou podemos tentar via notifyName\n// Estratégia: usar 'to' do payload se 'from' for @lid (pois o bot recebe de quem enviou)\n// NOTA: Em chats @lid o 'to' é o número do bot. O remetente real fica só no @lid sem telefone.\n// Solução: guardar o @lid completo como chatId para resposta direta.\nconst fromRaw = payload.from || '';\nlet phone;\nif (fromRaw.includes('@lid')) {\n  // Usar o from original com @lid como chatId (o WAHA WEBJS aceita @lid para envio)\n  phone = fromRaw; // ex: 118747406835835@lid\n} else {\n  phone = fromRaw.replace('@c.us', '').replace('@s.whatsapp.net', '');\n}\nconst message = (payload.body || payload.text || '').trim();\nconst session = body.session || 'default';\nconst msgId = payload.id || '';\n\n// Ignora mensagens vazias, de grupos ou do próprio bot\nif (!message || !phone || phone.includes('-') || (payload.fromMe === true)) {\n  return [];\n}\n\nreturn [{ json: { phone, message, session, msgId, rawBody: body } }];"
      },
