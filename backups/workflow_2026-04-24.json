      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Filtra apenas mensagens reais de texto (ignora e2e_notification, status, etc)\nconst isRealMessage = (\n  body.event === 'message' &&\n  !body.payload.fromMe &&\n  body.payload.body &&\n  body.payload.body.trim() !== '' &&\n  body.payload._data?.type !== 'e2e_notification'\n);\n\nif (isRealMessage) {\n  return $input.all();\n}\nreturn [];"
      },
