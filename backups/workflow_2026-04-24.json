    {
      "parameters": {
        "jsCode": "// Mescla dados extraídos com sessão do Postgres\nconst extracted = $input.all()[0]?.json || {};\nconst sessionRow = $input.all()[1]?.json || null;\n\nconst phone = extracted.phone;\nconst message = extracted.message;\nconst session = extracted.session;\nconst nicho = sessionRow?.nicho || null;\nconst historico = sessionRow?.historico ? JSON.parse(sessionRow.historico) : [];\n\nreturn [{ json: { phone, message, session, nicho, historico } }];"
      },
